<?xml version="1.0" encoding="utf-8"?>
<!-- android_app/app/src/main/res/layout/activity_main.xml -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#07080E"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Title Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Antigravity"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Universal Real-time Translator"
            android:textColor="#8B5CF6"
            android:textSize="14sp"
            android:layout_marginBottom="24dp"/>

        <!-- Description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ilova telefon qo'ng'iroqlari va messenjerlarda tarjima qilishi uchun zarur ruxsatnomalarni faollashtiring:"
            android:textColor="#9CA3AF"
            android:textSize="13sp"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="20dp"/>

        <!-- Permission 1 Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#16182B"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1. Mikrofon Ruxsati (Microphone)"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nutqni matnga aylantirish uchun audio yozib olish ruxsati kerak."
                android:textColor="#9CA3AF"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btn_grant_mic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Grant Permission"
                android:backgroundTint="#8B5CF6"/>
        </LinearLayout>

        <!-- Permission 2 Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#16182B"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2. Ekran ustidan chizish (Overlay)"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Qo'ng'iroq oynasi ustidan tarjimon subtitrlarini ko'rsatish uchun kerak."
                android:textColor="#9CA3AF"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btn_grant_overlay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Open Overlay Settings"
                android:backgroundTint="#06B6D4"/>
        </LinearLayout>

        <!-- Permission 3 Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#16182B"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3. Maxsus imkoniyatlar (Accessibility)"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="WhatsApp va Telegram'dagi ovozli qo'ng'iroqlarda tarjimon ishlashi uchun kerak."
                android:textColor="#9CA3AF"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btn_grant_accessibility"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Open Accessibility Settings"
                android:backgroundTint="#EC4899"/>
        </LinearLayout>

        <!-- Model Status Skeletons -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Offline Modellar (Status)"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="• Uzbek Model (Vosk): ACTIVE (150 MB)"
            android:textColor="#10B981"
            android:textSize="13sp"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="• NLLB Translation: ACTIVE (1200 MB)"
            android:textColor="#10B981"
            android:textSize="13sp"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="• English Model (Vosk): NOT INSTALLED (1500 MB)"
            android:textColor="#EF4444"
            android:textSize="13sp"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>
