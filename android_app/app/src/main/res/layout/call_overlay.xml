<?xml version="1.0" encoding="utf-8"?>
<!-- android_app/app/src/main/res/layout/call_overlay.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#E0101223"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_margin="12dp">

    <!-- Active status indicator -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="#FF8B5CF6"
            android:layout_marginEnd="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ANTIGRAVITY TRANSLATOR"
            android:textColor="#FF9CA3AF"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Subtitle original text -->
    <TextView
        android:id="@+id/tv_original"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ovoz yozilishi kutilmoqda..."
        android:textColor="#FF93C5FD"
        android:textSize="14sp"
        android:layout_marginBottom="6dp"/>

    <!-- Subtitle translated text -->
    <TextView
        android:id="@+id/tv_translated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="➔ Tarjima bu yerda chiqadi..."
        android:textColor="#FFFCA5A5"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"/>

    <!-- Translate control overlay button -->
    <Button
        android:id="@+id/btn_toggle_translate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Translate (ON)"
        android:backgroundTint="#FF8B5CF6"
        android:textColor="#FFFFFF"
        android:textStyle="bold"/>

</LinearLayout>
